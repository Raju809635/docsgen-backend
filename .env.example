GROQ_API_KEY=your_groq_api_key_here
# Optional
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Set to 1 to attempt json_schema (best-effort; auto-fallback enabled)
GROQ_USE_JSON_SCHEMA=0

# Hugging Face Image Generation
HUGGINGFACE_API_KEY=your_huggingface_token_here
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
VIDEO_WORKER_TOKEN=your_shared_colab_worker_token

# CORS
FRONTEND_ORIGIN=https://docsgen-frontend.vercel.app
